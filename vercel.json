{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "kautilyan.com" }],
      "destination": "https://www.kautilyan.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/blog/([^/]+)/?", "dest": "/article?slug=$1" },
    { "src": "/use-cases/([^/]+)/?", "dest": "/use-case-landing?slug=$1" }
  ]
}
