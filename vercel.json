{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "kautilyan.com" }],
      "destination": "https://www.kautilyan.com/:path*",
      "permanent": true
    },
    {
      "source": "/assessment",
      "destination": "/assessment.html",
      "permanent": false
    }
  ],
  "functions": {
    "api/submit-assessment.js": {
      "maxDuration": 30
    },
    "api/get-report.js": {
      "maxDuration": 10
    }
  },
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "GAS_EMAIL_WEBHOOK_URL": "@gas_email_webhook_url",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SITE_URL": "@site_url"
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/blog/([^/]+)/?", "dest": "/article?slug=$1" },
    { "src": "/use-cases/([^/]+)/?", "dest": "/use-case-landing?slug=$1" }
  ]
}
